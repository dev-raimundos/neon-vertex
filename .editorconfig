root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 120

[*.java]
ij_java_wrap_long_lines = true
ij_java_method_call_chain_wrap = normal
ij_java_call_parameters_wrap = on_every_item
ij_java_method_parameters_wrap = on_every_item
ij_java_imports_layout = br.api.neonvertex.**,|,lombok.**,org.springframework.**,|,jakarta.**,java.**,|,$*
ij_java_builder_methods = builder,build,name,email,cpf,password,phone,status,token,user,expiryDate
ij_java_keep_builder_methods_indents = true

[*.{yml,yaml}]
indent_size = 2

[*.xml]
indent_size = 4

[*.sql]
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false